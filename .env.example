# TrasTeoria v8.0 - Environment Variables

# ===== VITE CONFIGURATION =====
VITE_APP_NAME=TrasTeoria
VITE_APP_VERSION=8.0.0
VITE_ENVIRONMENT=production

# ===== API CONFIGURATION =====
VITE_API_URL=https://api.trasteoria.com
VITE_API_TIMEOUT=30000

# ===== AUDIO CONFIGURATION =====
VITE_AUDIO_SAMPLE_RATE=44100
VITE_AUDIO_BUFFER_SIZE=4096
VITE_AUDIO_MAX_VOICES=32

# ===== ANALYTICS =====
VITE_ANALYTICS_ENABLED=true
VITE_ANALYTICS_ID=

# ===== FEATURE FLAGS =====
VITE_FEATURE_ATLAS=true
VITE_FEATURE_LOOPER=true
VITE_FEATURE_MIDI=true
VITE_FEATURE_RECORDING=true
VITE_FEATURE_EFFECTS=true

# ===== PERFORMANCE =====
VITE_LAZY_LOAD_ENABLED=true
VITE_CODE_SPLITTING_ENABLED=true
VITE_PRELOAD_SAMPLES=false

# ===== DEBUG =====
VITE_DEBUG_MODE=false
VITE_LOG_LEVEL=warn
